# Backend environment variables
# Copy this file to .env and fill in the values

PORT=5000

# MongoDB connection string
# Local: mongodb://127.0.0.1:27017/BuzzTweet
# Atlas: mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/BuzzTweet
MONGO_URI=mongodb://127.0.0.1:27017/BuzzTweet

# Frontend URL(s) for CORS — comma-separated for multiple origins
FRONTEND_URL=http://localhost:5173

# JWT secret — generate a strong random string for production
# Example: openssl rand -hex 32
JWT_SECRET=

# OpenRouter API key for AI post generation (optional)
OPENROUTER_API_KEY=

# Set to "production" in deployment
NODE_ENV=development
